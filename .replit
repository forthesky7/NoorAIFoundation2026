modules = ["nodejs-24", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
NOWPAYMENTS_API_KEY = "ME14SB4-Y69M2P0-NKCW0NR-Y260NFX"
NOWPAYMENTS_WALLET = "0xC9E65529aE5954C795036E93eB654D3858dA2AE8"
NOWPAYMENTS_CURRENCY = "USDTERC20"
